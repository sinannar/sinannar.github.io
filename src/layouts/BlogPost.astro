---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props as Props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="post-main">
			<article>
				<header class="post-header">
					<p class="eyebrow">
						<a href="/blog">~/blog</a> <span class="muted">/ </span>
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<>
								<span class="muted"> · updated </span>
								<FormattedDate date={updatedDate} />
							</>
						)}
					</p>
					<h1 class="post-title">{title}</h1>
					{description && <p class="post-desc">{description}</p>}
				</header>

				{heroImage && (
					<div class="hero">
						<img src={heroImage} alt="" />
					</div>
				)}

				<div class="post-layout">
					{toc.length > 0 && (
						<aside class="toc-wrapper" aria-label="Table of contents">
							<nav class="toc">
								<p class="toc-title mono">On this page</p>
								<ol class="toc-list">
									{toc.map((heading) => (
										<li class={heading.depth === 3 ? 'toc-depth-3' : undefined}>
											<a href={`#${heading.slug}`}>{heading.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</aside>
					)}
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-main { max-width: var(--max-page); }
	.post-header {
		max-width: var(--max-content);
		margin: 0 auto 1.5rem;
	}
	.post-header .eyebrow a { color: var(--accent); }
	.post-title {
		margin: 0.25em 0 0.5em;
		font-size: clamp(1.8rem, 2.2vw + 1rem, 2.4rem);
	}
	.post-desc {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin: 0;
	}
	.hero {
		max-width: var(--max-page);
		margin: 1rem auto 2rem;
	}
	.hero img {
		width: 100%;
		max-height: 420px;
		object-fit: contain;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-1);
		background: var(--surface);
	}

	.post-layout {
		display: grid;
		grid-template-columns: 240px minmax(0, var(--max-content));
		gap: 2rem;
		justify-content: center;
		align-items: start;
	}
	.post-layout:has(.prose:only-child),
	.post-layout:not(:has(.toc-wrapper)) {
		grid-template-columns: minmax(0, var(--max-content));
	}

	.toc-wrapper { position: sticky; top: 88px; }
	.toc {
		padding: 1rem 1.1rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}
	.toc-title {
		margin: 0 0 0.6rem;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
	}
	.toc-list {
		margin: 0;
		padding-left: 1.1rem;
		font-size: 0.9rem;
	}
	.toc-list li { margin: 0.3rem 0; }
	.toc-list a { color: var(--text-muted); }
	.toc-list a:hover { color: var(--accent); }
	.toc-list .toc-depth-3 { margin-left: 0.9rem; }

	.prose { width: 100%; }

	@media (max-width: 980px) {
		.post-layout {
			grid-template-columns: minmax(0, var(--max-content));
		}
		.toc-wrapper {
			position: static;
			order: -1;
		}
		.toc { margin-bottom: 1rem; }
	}
</style>
