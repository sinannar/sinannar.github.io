---
interface Props {
  title: string;
  event: string;
  description: string;
  date: string;
  videoId?: string;
  href?: string;
  ctaLabel?: string;
}

const {
  title,
  event,
  description,
  date,
  videoId,
  href = videoId ? `https://www.youtube.com/watch?v=${videoId}` : "#",
  ctaLabel = "Watch on YouTube",
} = Astro.props;

const thumbnailSrc = videoId
  ? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`
  : null;
const thumbnailAlt = `${title} recording thumbnail`;
---

<li class="recording-card">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="recording-link"
  >
    <div class="recording-thumbnail-frame">
      {
        thumbnailSrc ? (
          <img src={thumbnailSrc} alt={thumbnailAlt} loading="lazy" />
        ) : (
          <div class="recording-thumbnail-fallback" aria-hidden="true">
            <span>Recording</span>
          </div>
        )
      }
      <span class="recording-play-badge">YouTube</span>
    </div>

    <div class="recording-body">
      <span class="recording-event">{event}</span>
      <h3 class="recording-title">{title}</h3>
      <p class="recording-desc">{description}</p>
      <div class="recording-footer">
        <span class="recording-date">{date}</span>
        <span class="recording-cta">{ctaLabel} &rarr;</span>
      </div>
    </div>
  </a>
</li>

<style>
  .recording-card {
    list-style: none;
  }

  .recording-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid rgba(209, 213, 219, 0.9);
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .recording-link:hover {
    transform: translateY(-4px);
    border-color: rgba(239, 68, 68, 0.35);
    box-shadow: 0 20px 36px rgba(15, 23, 42, 0.12);
  }

  .recording-thumbnail-frame {
    position: relative;
    aspect-ratio: 3 / 2;
    background: #111827;
  }

  .recording-thumbnail-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recording-thumbnail-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at top, rgba(239, 68, 68, 0.25), transparent 55%),
      linear-gradient(160deg, #111827 0%, #1f2937 100%);
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .recording-play-badge {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: rgba(17, 24, 39, 0.78);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .recording-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1rem 1.1rem;
  }

  .recording-event {
    color: #b91c1c;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .recording-title {
    margin: 0;
    color: #111827;
    font-size: 1rem;
    line-height: 1.35;
  }

  .recording-desc {
    margin: 0;
    color: #475569;
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .recording-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
  }

  .recording-date {
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .recording-cta {
    color: #dc2626;
    font-size: 0.82rem;
    font-weight: 700;
  }
</style>