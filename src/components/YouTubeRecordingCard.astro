---
interface Props {
  title: string;
  event: string;
  description: string;
  date: string;
  videoId?: string;
  href?: string;
  ctaLabel?: string;
}

const {
  title,
  event,
  description,
  date,
  videoId,
  href = videoId ? `https://www.youtube.com/watch?v=${videoId}` : "#",
  ctaLabel = "Watch on YouTube",
} = Astro.props;

const thumbnailSrc = videoId
  ? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`
  : null;
const thumbnailAlt = `${title} recording thumbnail`;
---

<li class="recording-card">
  <div class="recording-flip-inner">
    <div class="recording-face recording-front">
      <div class="recording-thumbnail-frame">
        {
          thumbnailSrc ? (
            <img src={thumbnailSrc} alt={thumbnailAlt} loading="lazy" />
          ) : (
            <div class="recording-thumbnail-fallback" aria-hidden="true">
              <span>Recording</span>
            </div>
          )
        }
      </div>

      <div class="recording-front-body">
        <span class="recording-event recording-event-front">{event}</span>
        <h3 class="recording-title recording-title-front">{title}</h3>
        <span class="recording-date recording-date-front">{date}</span>
      </div>
    </div>

    <div class="recording-face recording-back">
      <span class="recording-event">{event}</span>
      <h3 class="recording-title">{title}</h3>
      <p class="recording-desc">{description}</p>
      <div class="recording-footer">
        <span class="recording-date">{date}</span>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="recording-cta"
        >{ctaLabel} &rarr;</a>
      </div>
    </div>
  </div>
</li>

<style>
  .recording-card {
    list-style: none;
    width: 100%;
    perspective: 900px;
  }

  .recording-flip-inner {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    transform-style: preserve-3d;
    transition: transform 500ms cubic-bezier(0.4, 0.2, 0.2, 1);
    border-radius: 14px;
    box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
  }

  .recording-card:hover .recording-flip-inner {
    transform: rotateY(180deg);
  }

  .recording-face {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .recording-front {
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border: 1px solid rgba(209, 213, 219, 0.9);
  }

  .recording-back {
    background: linear-gradient(145deg, #3f0d0d 0%, #7f1d1d 100%);
    color: #fff;
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.1rem;
  }

  .recording-thumbnail-frame {
    position: relative;
    aspect-ratio: 3 / 2;
    background: #111827;
  }

  .recording-thumbnail-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recording-thumbnail-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at top, rgba(239, 68, 68, 0.25), transparent 55%),
      linear-gradient(160deg, #111827 0%, #1f2937 100%);
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .recording-front-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 1rem 1.15rem;
  }

  .recording-event {
    color: #fca5a5;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .recording-title {
    margin: 0;
    color: #fff;
    font-size: 1rem;
    line-height: 1.35;
  }

  .recording-title-front {
    color: #111827;
    text-align: left;
  }

  .recording-event-front {
    color: #dc2626;
  }

  .recording-date-front {
    color: #64748b;
  }

  .recording-desc {
    margin: 0;
    color: #fee2e2;
    font-size: 0.8rem;
    line-height: 1.55;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }

  .recording-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
  }

  .recording-date {
    color: #fecaca;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .recording-cta {
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    padding: 0.35rem 0.75rem;
  }

  .recording-cta:hover {
    background: rgba(255, 255, 255, 0.22);
  }
</style>