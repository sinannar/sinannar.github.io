---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Speaking | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main>
      <section style="max-width: 900px; margin: 2rem auto;">
        <h1
          style="font-size:2.2rem; margin-bottom:1.5rem; border-bottom: 2px solid #eee; padding-bottom: 0.5rem;"
        >
          Public Speaking &amp; Meetups
        </h1>

        <!-- Speaking Engagements -->
        <h2 style="font-size:1.5rem; margin-bottom:1rem;">Public Speakings</h2>

        <ul class="talks-list">
          {talks.map((talk) => <TalkFlipCard {...talk} />)}
        </ul>

        <h2 style="font-size:1.5rem; margin-bottom:1rem;">YouTube Recordings</h2>

        {
          recordings.length > 0 ? (
            <ul class="recordings-list">
              {recordings.map((recording) => <YouTubeRecordingCard {...recording} />)}
            </ul>
          ) : (
            <p class="section-empty-state">
              YouTube recordings will live here once the session videos are published.
            </p>
          )
        }
      

        <!-- Organiser Groups -->
        <h2 style="font-size:1.5rem; margin-bottom:1rem;">Organizer for</h2>

        <ul class="group-list">
          {organizerGroups.map((group) => <OrganizerCard {...group} />)}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-warning {
    margin: 0 0 1.5rem;
    padding: 0.75rem 0.95rem;
    border-radius: 10px;
    border: 1px solid #facc15;
    background: #fffbeb;
    color: #854d0e;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .group-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .talks-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .recordings-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .section-empty-state {
    margin: 0 0 2.5rem;
    padding: 1rem 1.1rem;
    border: 1px dashed rgba(148, 163, 184, 0.9);
    border-radius: 16px;
    background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
    color: #475569;
    font-size: 0.95rem;
  }

  @media (max-width: 720px) {
    .group-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .talks-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .recordings-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) and (min-width: 721px) {
    .group-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .talks-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .recordings-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
