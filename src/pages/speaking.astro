---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Speaking | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main>
      <section style="max-width: 900px; margin: 2rem auto;">
        <h1
          style="font-size:2.2rem; margin-bottom:1.5rem; border-bottom: 2px solid #eee; padding-bottom: 0.5rem;"
        >
          Public Speaking &amp; Meetups
        </h1>

        <!-- Speaking Engagements -->
        <h2 style="font-size:1.5rem; margin-bottom:1rem;">Public Speakings</h2>

        <ul class="talks-list">
          {talks.map((talk) => <TalkFlipCard {...talk} />)}
        </ul>

        <h2 style="font-size:1.5rem; margin-bottom:1rem;">YouTube Recordings</h2>

        {
          recordings.length > 0 ? (
            <ul class="recordings-list">
              {recordings.map((recording) => <YouTubeRecordingCard {...recording} />)}
            </ul>
          ) : (
            <p class="section-empty-state">
              YouTube recordings will live here once the session videos are published.
            </p>
          )
        }
      

        <!-- Organiser Groups -->
        <h2 style="font-size:1.5rem; margin-bottom:1rem;">Organizer for</h2>

        <ul class="group-list">
          <li>
            <a
              href="https://www.meetup.com/akl-net/"
              target="_blank"
              rel="noopener noreferrer"
              class="group-pill"
            >
              <span class="group-image-frame">
              <img
                src="/meetups/groups/dotnet-ug.avif"
                alt="Auckland .NET User Group logo"
              />
              <span class="group-name">Auckland .NET User Group</span>
              </span>
            </a>
          </li>
          <li>
            <a
              href="https://www.meetup.com/auckland-azure-usergroup/"
              target="_blank"
              rel="noopener noreferrer"
              class="group-pill"
            >
              <span class="group-image-frame">
              <img
                src="/meetups/groups/azure-ug.avif"
                alt="Aotearoa Azure Meetup logo"
              />
              <span class="group-name">Aotearoa Azure Meetup</span>
              </span>
            </a>
          </li>

        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-warning {
    margin: 0 0 1.5rem;
    padding: 0.75rem 0.95rem;
    border-radius: 10px;
    border: 1px solid #facc15;
    background: #fffbeb;
    color: #854d0e;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .group-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .group-list li {
    flex: 1 1 320px;
    max-width: 360px;
  }

  .group-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    text-decoration: none;
    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .group-pill:hover {
    transform: translateY(-5px);
    filter: saturate(1.04);
  }

  .group-image-frame {
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 220px;
    padding: 1rem;
    background:
      radial-gradient(circle at top, rgba(35, 55, 255, 0.1), transparent 60%),
      linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
    border: 1px solid rgba(183, 199, 247, 0.7);
    border-radius: 28px;
    box-shadow:
      0 18px 34px rgba(38, 66, 156, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .group-pill img {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 12px;
    filter: drop-shadow(0 14px 24px rgba(35, 55, 255, 0.12));
  }

  .group-name {
    color: #324488;
    font-weight: 700;
    font-size: 0.98rem;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .talks-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .recordings-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .section-empty-state {
    margin: 0 0 2.5rem;
    padding: 1rem 1.1rem;
    border: 1px dashed rgba(148, 163, 184, 0.9);
    border-radius: 16px;
    background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
    color: #475569;
    font-size: 0.95rem;
  }

  @media (max-width: 720px) {
    .group-list {
      gap: 1.5rem;
    }

    .group-image-frame {
      min-height: 190px;
      border-radius: 22px;
    }

    .group-pill img {
      max-width: 260px;
    }

    .talks-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .recordings-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) and (min-width: 721px) {
    .talks-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .recordings-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
