<style>
  .page-warning {
    margin: 0 0 1.5rem;
    padding: 0.75rem 0.95rem;
    border-radius: 10px;
    border: 1px solid #facc15;
    background: #fffbeb;
    color: #854d0e;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .group-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .group-list li {
    flex: 1 1 320px;
    max-width: 360px;
  }

  .group-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    text-decoration: none;
    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .group-pill:hover {
    transform: translateY(-5px);
    filter: saturate(1.04);
  }

  .group-image-frame {
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 220px;
    padding: 1rem;
    background:
      radial-gradient(circle at top, rgba(35, 55, 255, 0.1), transparent 60%),
      linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
    border: 1px solid rgba(183, 199, 247, 0.7);
    border-radius: 28px;
    box-shadow:
      0 18px 34px rgba(38, 66, 156, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .group-pill img {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 12px;
    filter: drop-shadow(0 14px 24px rgba(35, 55, 255, 0.12));
  }

  .group-name {
    color: #324488;
    font-weight: 700;
    font-size: 0.98rem;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .talks-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  /* ── Flip card ── */
  .talk-flip-wrapper {
    width: 100%;
    perspective: 900px;
  }

  .talk-flip-inner {
    position: relative;
    width: 100%;
    /* height is driven by the aspect ratio of the front image (~4:3 for the flyer) */
    aspect-ratio: 3 / 4;
    transform-style: preserve-3d;
    transition: transform 500ms cubic-bezier(0.4, 0.2, 0.2, 1);
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(38, 66, 156, 0.10);
  }

  .talk-flip-wrapper:hover .talk-flip-inner {
    transform: rotateY(180deg);
  }

  .talk-face {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  /* Front */
  .talk-front {
    background: #0d1b2a;
  }

  .talk-front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Back */
  .talk-back {
    background: linear-gradient(145deg, #0f1f3d 0%, #1a3a6e 100%);
    color: #fff;
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 1.1rem;
  }

  .talk-event {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #60a5fa;
  }

  .talk-title {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
  }

  .talk-desc {
    margin: 0;
    font-size: 0.7rem;
    color: #bfdbfe;
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }

  .talk-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .talk-date,
  .talk-location {
    font-size: 0.75rem;
    color: #93c5fd;
  }

  .talk-date::before { content: "📅 "; }
  .talk-location::before { content: "📍 "; }

  .talk-link {
    margin-top: 0.5rem;
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 8px;
    padding: 0.35rem 0.75rem;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .talk-link:hover {
    background: rgba(255,255,255,0.28);
  }

  @media (max-width: 720px) {
    .group-list {
      gap: 1.5rem;
    }

    .group-image-frame {
      min-height: 190px;
      border-radius: 22px;
    }

    .group-pill img {
      max-width: 260px;
    }

    .talks-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 1024px) and (min-width: 721px) {
    .talks-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
